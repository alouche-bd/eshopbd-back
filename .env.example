APP_NAME=Eshop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
DEFAULT_ERROR_LEVEL=3

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=biotech_shop
DB_USERNAME=biotech_shop_user
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

JWT_SECRET=

# Sage X3 / middleware integration ---------------------------------
# Existing legacy var, still read as a fallback by config/x3.php.
BASE_MIDDLEWARE=BIOTECH

# Distributor workflow — preferred name going forward.
# LOCAL/STAGING: BDRCT     PRODUCTION: BIOTECH
# (note: the original spec wrote "BRDCT" but the actual local base is BDRCT)
X3_BASE=BDRCT
X3_SENDORDER_MODEL=ZSOH
X3_SENDORDER_PATH=/api/v3/sendorder
X3_SITE=CRAP
X3_ORDER_TYPE=SON

# Mailbox that receives the distributor Excel export (§7, §10).
ADV_INTER_EMAIL=adv-inter@biotech-dental.com

# Middleware proxy (already used by the legacy code).
MIDDLEWARE_SERVICE_BASE_URL=https://api-galaxy.biotech-dental.com
MIDDLE_SERVICE_SECRET=

URL_SSO=https://01.fr.sso.biotechgalaxy.com/v1/
BROKER_SECRET=
BROKER_UUID=

URL_S4A=https://01.fr.api.biotechgalaxy.com/
S4A_UUID=
S4A_CLIENT=biotech-dental-eshop
S4A_SECRET=

OAUTH_URI=https://01.fr.oauth.biotechgalaxy.com/
