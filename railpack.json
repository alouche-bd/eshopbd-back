{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "php": "8.2"
  },
  "buildAptPackages": [
    "bison",
    "re2c",
    "libcurl4-openssl-dev",
    "libreadline-dev",
    "libonig-dev",
    "libpq-dev",
    "libicu-dev",
    "libzip-dev",
    "libgd-dev",
    "libpng-dev",
    "libjpeg-dev",
    "libfreetype6-dev",
    "libxml2-dev",
    "libssl-dev"
  ],
  "deploy": {
    "startCommand": "php -S 0.0.0.0:${PORT:-8000} -t public public/index.php"
  }
}
